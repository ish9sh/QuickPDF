node_modules/
dist/
coverage/
.DS_Store
*.log
.kiro/
.claude/

# Secrets / environment files — never commit
.env
.env.*
**/.env
**/.env.*

# macOS AppleDouble / scratch files (e.g. ._foo)
._*

# Python backend (local virtualenv & caches) — never commit these
backend/venv/
__pycache__/
*.pyc

# Test fixtures are real PDFs with personal data — keep them LOCAL only, never commit.
backend/tests/fixtures/*.pdf

# Test/sample PDFs are never committed (test-document.pdf is regenerable via create-test-pdf.js).
*.pdf

# The ROOT tests/ tree is kept LOCAL only — never committed, on any branch (jest suite,
# agentic harness, fixtures and personal sample PDFs all stay on disk, not in git). Anchored to
# the repo root with a leading slash so it does NOT also shadow backend/tests/ (the committed
# Python suite that runs as the build gate).
/tests/

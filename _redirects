# Netlify clean URLs: serve the .html content pages at extension-less paths.
# (200 = rewrite, so the URL stays clean and canonical tags match.)
/about      /about.html      200
/privacy    /privacy.html    200
/terms      /terms.html      200
/contact    /contact.html    200

# SPA fallback: any path not matched above (e.g. deep-link refreshes) is
# served as index.html with a 200 so the JS router can handle it client-side.
/*          /index.html      200
